ELEVENLABS_API_KEY=<ELEVENLABS_API_KEY> # api key from ElevenLabs
ELEVENLABS_VOICE_ID=<ELEVENLABS_VOICE_ID> # voice id from ElevenLabs
ELEVENLABS_MODEL_ID=<ELEVENLABS_MODEL_ID> # eleven_v3, eleven_v2, eleven_multilingual_v2, etc.
ELEVENLABS_OUTPUT_FORMAT=<ELEVENLABS_OUTPUT_FORMAT> # mp3_44100_128, mp3_24000_128, mp3_44100_128, etc.
GROQ_API_KEY=<GROQ_API_KEY> # Groq key for AI submission scoring
LLM_PROVIDER=groq
LLM_MODEL=llama-3.3-70b-versatile
# Use the local Codex CLI instead of Groq:
# LLM_PROVIDER=codex
# CODEX_MODEL=gpt-5.2
# CODEX_PROFILE=<optional-codex-profile>
# CODEX_OSS=false
# CODEX_LOCAL_PROVIDER=<ollama-or-lmstudio-if-CODEX_OSS-true>
# CODEX_TIMEOUT_SECONDS=300
AUTH_WEBHOOK_SECRET=<AUTH_WEBHOOK_SECRET> # optional local secret for auth webhook signature verification
# In Docker, forward scoring to a host-local server.py that can run Codex CLI:
# CODEX_REMOTE_URL=http://host.docker.internal:4174/api/evaluate

# Stripe billing
STRIPE_SECRET_KEY=<STRIPE_SECRET_KEY>
STRIPE_WEBHOOK_SECRET=<STRIPE_WEBHOOK_SECRET>
STRIPE_PRICE_SINGLE_EXAM=<STRIPE_PRICE_SINGLE_EXAM_PRICE_ID>
STRIPE_PRICE_EXAM_PACK=<STRIPE_PRICE_EXAM_PACK_PRICE_ID>
STRIPE_PRICE_MONTHLY_SUBSCRIPTION=<STRIPE_PRICE_MONTHLY_SUBSCRIPTION_PRICE_ID>
STRIPE_PRICE_AI_CREDITS=<STRIPE_PRICE_AI_CREDITS_PRICE_ID>
BILLING_DB_PATH=data/billing.sqlite3
